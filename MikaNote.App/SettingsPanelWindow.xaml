<Window x:Class="MikaNote.App.SettingsPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Width="160"
        Background="#00FFFFFF"
        AllowsTransparency="True">
    <Border x:Name="SettingsRootBorder"
            Width="160"
            Background="#2A2A2A"
            BorderBrush="#1E1E1E"
            BorderThickness="1"
            Padding="10">
        <StackPanel>
            <TextBlock x:Name="SettingsTitleTextBlock"
                       Margin="0,0,0,8"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="Settings" />

            <StackPanel x:Name="FontSettingsPanel"
                        Visibility="Collapsed">
                <TextBlock Margin="0,0,0,8"
                           Foreground="#D0D0D0"
                           Text="Title text size" />
                <WrapPanel x:Name="TitleFontSizeOptionsPanel">
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Title:12" Content="12" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Title:14" Content="14" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Title:16" Content="16" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Title:18" Content="18" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Title:22" Content="22" />
                </WrapPanel>

                <TextBlock Margin="0,4,0,8"
                           Foreground="#D0D0D0"
                           Text="Content text size" />
                <WrapPanel x:Name="ContentFontSizeOptionsPanel">
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Content:12" Content="12" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Content:14" Content="14" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Content:16" Content="16" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Content:18" Content="18" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="Content:22" Content="22" />
                </WrapPanel>

                <TextBlock Margin="0,4,0,8"
                           Foreground="#D0D0D0"
                           Text="Title line spacing" />
                <WrapPanel x:Name="TitleLineSpacingOptionsPanel">
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="TitleLine:1.0" Content="1.0" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="TitleLine:1.2" Content="1.2" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="TitleLine:1.3" Content="1.3" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="TitleLine:1.5" Content="1.5" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="TitleLine:1.8" Content="1.8" />
                </WrapPanel>

                <TextBlock Margin="0,4,0,8"
                           Foreground="#D0D0D0"
                           Text="Content line spacing" />
                <WrapPanel x:Name="ContentLineSpacingOptionsPanel">
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="ContentLine:1.0" Content="1.0" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="ContentLine:1.2" Content="1.2" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="ContentLine:1.3" Content="1.3" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="ContentLine:1.5" Content="1.5" />
                    <Button Margin="0,0,6,6" Padding="8,3" Tag="ContentLine:1.8" Content="1.8" />
                </WrapPanel>
            </StackPanel>

            <StackPanel x:Name="ColorSettingsPanel"
                        Visibility="Collapsed">
                <TextBlock Margin="0,0,0,8"
                           Foreground="#D0D0D0"
                           Text="Note background" />
                <WrapPanel x:Name="ColorOptionsPanel">
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FFF4A0" Tag="#FFF4A0" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#F9DCC4" Tag="#F9DCC4" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FEC89A" Tag="#FEC89A" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FBC4AB" Tag="#FBC4AB" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FFD6A5" Tag="#FFD6A5" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FFB4A2" Tag="#FFB4A2" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FAEDCB" Tag="#FAEDCB" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#C9E4DE" Tag="#C9E4DE" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#D8E2DC" Tag="#D8E2DC" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#CDEAC0" Tag="#CDEAC0" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#BDE0FE" Tag="#BDE0FE" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#A9DEF9" Tag="#A9DEF9" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#E4C1F9" Tag="#E4C1F9" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#3A3A3A" Tag="#3A3A3A" />
                    <Button Width="26" Height="26" Margin="0,0,6,6" Background="#FFFFFF" Tag="#FFFFFF" />
                </WrapPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
