<Window x:Class="MikaNote.App.ActionBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        Width="320"
        Height="36"
        Background="#00FFFFFF"
        AllowsTransparency="True">
    <Border x:Name="ActionBarRootBorder"
            Height="36"
            Background="#2A2A2A"
            BorderBrush="#1E1E1E"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="NewNoteButton"
                    Grid.Column="0"
                    Margin="2,3,4,3"
                    Width="30"
                    Padding="0"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Content="+"
                    Foreground="White"
                    Background="#4A4A4A"
                    BorderBrush="#686868"
                    ToolTip="New note">
                <Button.ContextMenu>
                    <ContextMenu x:Name="NewNoteContextMenu"
                                 Placement="Bottom">
                        <MenuItem x:Name="NewStickyMemoMenuItem"
                                  Header="New Sticky Memo" />
                        <MenuItem x:Name="NewTodoMemoMenuItem"
                                  Header="New Todo Memo" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>

            <Button x:Name="ColorButton"
                    Grid.Column="1"
                    Margin="0,3,4,3"
                    Width="30"
                    Padding="0"
                    Foreground="White"
                    Background="#4A4A4A"
                    BorderBrush="#686868"
                    ToolTip="Color settings">
                <Grid Width="15"
                      Height="15">
                    <Ellipse Width="13"
                             Height="13"
                             Fill="#F4D06F"
                             Stroke="White"
                             StrokeThickness="0.8" />
                    <Ellipse Width="2.6"
                             Height="2.6"
                             Margin="3.1,3.0,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#FF8A80" />
                    <Ellipse Width="2.6"
                             Height="2.6"
                             Margin="0,3.0,3.0,0"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Fill="#82B1FF" />
                    <Ellipse Width="2.6"
                             Height="2.6"
                             Margin="3.1,0,0,3.0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Fill="#A5D6A7" />
                    <Ellipse Width="4"
                             Height="4"
                             Margin="0,0,2.8,2.7"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Fill="#4A4A4A" />
                </Grid>
            </Button>

            <Button x:Name="TextSizeButton"
                    Grid.Column="2"
                    Margin="0,3,4,3"
                    Width="30"
                    Padding="0"
                    Foreground="White"
                    Background="#4A4A4A"
                    BorderBrush="#686868"
                    ToolTip="Text settings">
                <Grid Width="15"
                      Height="15">
                    <TextBlock Text="A"
                               FontSize="11.5"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" />
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0.2,0,0">
                        <Rectangle Width="4.6"
                                   Height="1.4"
                                   Margin="0,0,0,2"
                                   RadiusX="0.7"
                                   RadiusY="0.7"
                                   Fill="White" />
                        <Rectangle Width="4.6"
                                   Height="1.4"
                                   RadiusX="0.7"
                                   RadiusY="0.7"
                                   Fill="White" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button x:Name="ManagerButton"
                    Grid.Column="4"
                    Margin="0,3,4,3"
                    Width="34"
                    Padding="0"
                    Foreground="White"
                    Background="#4A4A4A"
                    BorderBrush="#686868"
                    ToolTip="Open manager"
                    Visibility="Collapsed">
                <TextBlock Text="&#x00B7;&#x00B7;&#x00B7;"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Button>

            <Button x:Name="SaveButton"
                    Grid.Column="4"
                    Margin="0,3,4,3"
                    Padding="8,0"
                    Content="Save"
                    Foreground="White"
                    Background="#4A4A4A"
                    BorderBrush="#686868"
                    Visibility="Collapsed" />

            <Button x:Name="CloseButton"
                    Grid.Column="5"
                    Width="30"
                    Margin="0,3,2,3"
                    Content="X"
                    Foreground="White"
                    Background="#4A4A4A"
                    BorderBrush="#686868"
                    Visibility="Collapsed" />
        </Grid>
    </Border>
</Window>
