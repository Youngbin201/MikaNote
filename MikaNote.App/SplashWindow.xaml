<Window x:Class="MikaNote.App.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320"
        Height="224"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True">
    <Border Background="#FFF8F0"
            BorderBrush="#E5D8C6"
            BorderThickness="1"
            CornerRadius="24"
            Padding="24">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Image x:Name="BrandImage"
                   Width="96"
                   Height="96"
                   Margin="0,0,0,16"
                   Stretch="Uniform" />
            <TextBlock HorizontalAlignment="Center"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="#2D261F"
                       Text="MikaNote" />
            <TextBlock Margin="0,8,0,0"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="#7D7368"
                       Text="Preparing your notes..." />
        </StackPanel>
    </Border>
</Window>
