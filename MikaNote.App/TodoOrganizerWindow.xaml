<Window x:Class="MikaNote.App.TodoOrganizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        Width="108"
        Height="96"
        Background="#00FFFFFF"
        AllowsTransparency="True">
    <Border x:Name="OrganizerRootBorder"
            Width="108"
            Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Height}"
            Background="#2A2A2A"
            BorderBrush="#1E1E1E"
            BorderThickness="1"
            Padding="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="0,0,0,5"
                       Foreground="#B8B8B8"
                       FontSize="9"
                       TextWrapping="Wrap">
                Drag to reorder
                <LineBreak />
                X to delete
            </TextBlock>
            <ScrollViewer x:Name="OrganizerScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly">
                <StackPanel x:Name="OrganizerItemsPanel" />
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
