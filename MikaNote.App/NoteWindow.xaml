<Window x:Class="MikaNote.App.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="MikaNote"
        Width="320"
        Height="220"
        MinWidth="180"
        MinHeight="140"
        ResizeMode="CanResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="#00FFFFFF"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="TodoAddButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            Background="#FFEFA0"
            BorderBrush="Transparent"
            BorderThickness="0"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Popup x:Name="ActionPopup"
                   Placement="Custom"
                   PlacementTarget="{Binding ElementName=RootBorder}"
                   CustomPopupPlacementCallback="ActionPopup_CustomPopupPlacement"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   IsOpen="False">
                <Border x:Name="ActionPopupBorder"
                        Width="{Binding ActualWidth, ElementName=RootBorder}"
                        Height="28"
                        Background="#2A2A2A"
                        BorderBrush="#1E1E1E"
                        BorderThickness="1"
                        MouseEnter="ActionPopup_MouseEnter"
                        MouseLeave="ActionPopup_MouseLeave">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ManagerButton"
                                Grid.Column="0"
                                Margin="2,2,4,2"
                                Padding="8,0"
                                FontFamily="Segoe Fluent Icons"
                                Content="&#xE713;"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderBrush="#686868"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Open manager"
                                Click="ManagerButton_Click" />

                        <Button x:Name="TextSizeButton"
                                Grid.Column="1"
                                Margin="0,2,4,2"
                                Width="28"
                                Padding="0"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderBrush="#686868"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Text settings"
                                Click="TextSizeButton_Click">
                            <Grid Width="14"
                                  Height="14">
                                <TextBlock Text="A"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center" />
                                <StackPanel HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0.2,0,0">
                                    <Rectangle Width="4.6"
                                               Height="1.4"
                                               Margin="0,0,0,2"
                                               RadiusX="0.7"
                                               RadiusY="0.7"
                                               Fill="White" />
                                    <Rectangle Width="4.6"
                                               Height="1.4"
                                               RadiusX="0.7"
                                               RadiusY="0.7"
                                               Fill="White" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="ColorButton"
                                Grid.Column="2"
                                Margin="0,2,4,2"
                                Width="28"
                                Padding="0"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderBrush="#686868"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Color settings"
                                Click="ColorButton_Click">
                            <Grid Width="14"
                                  Height="14">
                                <Ellipse Width="12"
                                         Height="12"
                                         Fill="#F4D06F"
                                         Stroke="White"
                                         StrokeThickness="0.8" />
                                <Ellipse Width="2.6"
                                         Height="2.6"
                                         Margin="3.1,3.0,0,0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Fill="#FF8A80" />
                                <Ellipse Width="2.6"
                                         Height="2.6"
                                         Margin="0,3.0,3.0,0"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Fill="#82B1FF" />
                                <Ellipse Width="2.6"
                                         Height="2.6"
                                         Margin="3.1,0,0,3.0"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Bottom"
                                         Fill="#A5D6A7" />
                                <Ellipse Width="4"
                                         Height="4"
                                         Margin="0,0,2.8,2.7"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Bottom"
                                         Fill="#4A4A4A" />
                            </Grid>
                        </Button>

                        <Button x:Name="SaveButton"
                                Grid.Column="4"
                                Margin="0,2,4,2"
                                Padding="8,0"
                                Content="Save"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderBrush="#686868"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Visibility="Collapsed"
                                Click="SaveButton_Click" />

                        <Button x:Name="CloseButton"
                                Grid.Column="5"
                                Width="28"
                                Margin="0,2,2,2"
                                Content="X"
                                Foreground="White"
                                Background="#4A4A4A"
                                BorderBrush="#686868"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Visibility="Collapsed"
                                Click="CloseButton_Click" />
                    </Grid>
                </Border>
            </Popup>

            <Popup x:Name="SettingsPopup"
                   Placement="Custom"
                   PlacementTarget="{Binding ElementName=RootBorder}"
                   CustomPopupPlacementCallback="SettingsPopup_CustomPopupPlacement"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   IsOpen="False">
                <Border x:Name="SettingsPopupBorder"
                        Width="160"
                        Background="#2A2A2A"
                        BorderBrush="#1E1E1E"
                        BorderThickness="1"
                        Padding="10"
                        MouseEnter="SettingsPopup_MouseEnter"
                        MouseLeave="SettingsPopup_MouseLeave">
                    <StackPanel>
                        <TextBlock x:Name="SettingsPopupTitle"
                                   Margin="0,0,0,8"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="Settings" />

                        <StackPanel x:Name="FontSettingsPanel"
                                    Visibility="Collapsed">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="#D0D0D0"
                                       Text="Title text size" />
                            <WrapPanel x:Name="TitleFontSizeOptionsPanel">
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Title:12"
                                        Content="12"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Title:14"
                                        Content="14"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Title:16"
                                        Content="16"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Title:18"
                                        Content="18"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Title:22"
                                        Content="22"
                                        Click="FontSizeOption_Click" />
                            </WrapPanel>
                            <TextBlock Margin="0,4,0,8"
                                       Foreground="#D0D0D0"
                                       Text="Content text size" />
                            <WrapPanel x:Name="ContentFontSizeOptionsPanel">
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Content:12"
                                        Content="12"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Content:14"
                                        Content="14"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Content:16"
                                        Content="16"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Content:18"
                                        Content="18"
                                        Click="FontSizeOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="Content:22"
                                        Content="22"
                                        Click="FontSizeOption_Click" />
                            </WrapPanel>
                            <TextBlock Margin="0,4,0,8"
                                       Foreground="#D0D0D0"
                                       Text="Title line spacing" />
                            <WrapPanel x:Name="TitleLineSpacingOptionsPanel">
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="TitleLine:1.0"
                                        Content="1.0"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="TitleLine:1.2"
                                        Content="1.2"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="TitleLine:1.3"
                                        Content="1.3"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="TitleLine:1.5"
                                        Content="1.5"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="TitleLine:1.8"
                                        Content="1.8"
                                        Click="LineSpacingOption_Click" />
                            </WrapPanel>
                            <TextBlock Margin="0,4,0,8"
                                       Foreground="#D0D0D0"
                                       Text="Content line spacing" />
                            <WrapPanel x:Name="ContentLineSpacingOptionsPanel">
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="ContentLine:1.0"
                                        Content="1.0"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="ContentLine:1.2"
                                        Content="1.2"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="ContentLine:1.3"
                                        Content="1.3"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="ContentLine:1.5"
                                        Content="1.5"
                                        Click="LineSpacingOption_Click" />
                                <Button Margin="0,0,6,6"
                                        Padding="8,3"
                                        Tag="ContentLine:1.8"
                                        Content="1.8"
                                        Click="LineSpacingOption_Click" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel x:Name="ColorSettingsPanel"
                                    Visibility="Collapsed">
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="#D0D0D0"
                                       Text="Note background" />
                            <WrapPanel>
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FFF4A0"
                                        Tag="#FFF4A0"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#F9DCC4"
                                        Tag="#F9DCC4"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FEC89A"
                                        Tag="#FEC89A"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FBC4AB"
                                        Tag="#FBC4AB"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FFD6A5"
                                        Tag="#FFD6A5"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FFB4A2"
                                        Tag="#FFB4A2"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FAEDCB"
                                        Tag="#FAEDCB"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#C9E4DE"
                                        Tag="#C9E4DE"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#D8E2DC"
                                        Tag="#D8E2DC"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#CDEAC0"
                                        Tag="#CDEAC0"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#BDE0FE"
                                        Tag="#BDE0FE"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#A9DEF9"
                                        Tag="#A9DEF9"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#E4C1F9"
                                        Tag="#E4C1F9"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#3A3A3A"
                                        Tag="#3A3A3A"
                                        Click="ColorOption_Click" />
                                <Button Width="26"
                                        Height="26"
                                        Margin="0,0,6,6"
                                        Background="#FFFFFF"
                                        Tag="#FFFFFF"
                                        Click="ColorOption_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>

            <Grid x:Name="TitleAreaRoot"
                  Grid.Row="0"
                  Background="#FFF4A0"
                  MouseEnter="TitleArea_MouseEnter"
                  MouseLeave="TitleArea_MouseLeave"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleTextBlock"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           Margin="10,0,10,0"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <TextBox x:Name="TitleEditor"
                         Margin="8,4,8,4"
                         VerticalContentAlignment="Center"
                         TextAlignment="Center"
                         shell:WindowChrome.IsHitTestVisibleInChrome="True"
                         Visibility="Collapsed" />
            </Grid>

            <Grid x:Name="BodyAreaRoot"
                  Grid.Row="1"
                  Background="#FFF4A0"
                  PreviewMouseLeftButtonDown="Body_MouseLeftButtonDown">
                <ScrollViewer x:Name="ContentScrollViewer"
                              Margin="0"
                              Padding="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalOnly">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}">
                            <Setter Property="Width" Value="3" />
                            <Setter Property="Opacity" Value="0" />
                            <Setter Property="Background" Value="#18000000" />
                            <Setter Property="Margin" Value="0,8,1,8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                                        <Border Width="{TemplateBinding Width}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="3">
                                            <Track x:Name="PART_Track"
                                                   IsDirectionReversed="True"
                                                   Focusable="False">
                                                <Track.Thumb>
                                                    <Thumb />
                                                </Track.Thumb>
                                            </Track>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=BodyAreaRoot}"
                                             Value="True">
                                    <Setter Property="Opacity" Value="1" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="{x:Type Thumb}">
                            <Setter Property="Background" Value="#7A555555" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="3" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ScrollViewer.Resources>
                    <Grid Margin="10">
                        <TextBlock x:Name="ContentTextBlock"
                                   TextWrapping="Wrap" />
                        <StackPanel x:Name="TodoItemsPanel"
                                    Visibility="Collapsed" />
                    </Grid>
                </ScrollViewer>

                <TextBox x:Name="ContentEditor"
                         Margin="0"
                         Padding="10,8"
                         Visibility="Collapsed"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         PreviewMouseLeftButtonDown="ContentEditor_PreviewMouseLeftButtonDown"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled" />

                <ScrollViewer x:Name="TodoEditorScrollViewer"
                              Margin="8"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              PanningMode="VerticalOnly">
                    <StackPanel x:Name="TodoEditorPanel" />
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
